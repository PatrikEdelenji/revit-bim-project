# Data source configuration
# Options: "file" or "revit_api"
DATA_SOURCE=file

# File-based source settings (used when DATA_SOURCE=file)
FILE_PATH=data/raw/revit_rooms_export.txt
FILE_SKIPROWS=1

# Revit API settings (used when DATA_SOURCE=revit_api)
# The C# add-in running in Revit should expose these endpoints
REVIT_API_URL=http://localhost:5000
REVIT_API_TIMEOUT=30
REVIT_API_RETRIES=3
REVIT_API_RETRY_DELAY=1.0

# Output settings
OUTPUT_PATH=data/processed/rooms.parquet
